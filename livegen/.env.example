# LiveKit Configuration
LIVEKIT_API_KEY=dev
LIVEKIT_API_SECRET=secret

# AI Provider Keys (required)
GOOGLE_API_KEY=your_google_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# LiveKit URL (for agent to connect to)
LIVEKIT_URL=http://localhost:7880

# Model Configuration
GOOGLE_LLM_MODEL=gemini-2.0-flash-exp
NVIDIA_TTS_VOICE=ai-red-echo
NVIDIA_ASR_MODEL=parakeet-1.1b-rnnt-multilingual-asr

# Logging
LOG_LEVEL=INFO

# Optional: Redis for metrics storage
# REDIS_URL=redis://localhost:6379